# SmeAccounting .editorconfig
root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
charset = utf-8

[*.md]
indent_size = 2
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.cs]
indent_size = 4
max_line_length = 160

# === DESIGN ===
dotnet_diagnostic.CA1000.severity = warning
dotnet_diagnostic.CA1031.severity = warning
dotnet_diagnostic.CA1032.severity = warning
dotnet_diagnostic.CA1034.severity = warning
dotnet_diagnostic.CA1052.severity = warning

# === PERFORMANCE ===
dotnet_diagnostic.CA1822.severity = warning
dotnet_diagnostic.CA1845.severity = suggestion
dotnet_diagnostic.CA1846.severity = suggestion
dotnet_diagnostic.CA1852.severity = error
dotnet_diagnostic.CA1861.severity = warning

# === RELIABILITY ===
dotnet_diagnostic.CA2007.severity = suggestion
dotnet_diagnostic.CA2016.severity = error

# === USAGE ===
dotnet_diagnostic.CA2201.severity = error
dotnet_diagnostic.CA2208.severity = error

# === SECURITY ===
dotnet_diagnostic.CA2100.severity = error
dotnet_diagnostic.CA3001.severity = error
dotnet_diagnostic.CA3002.severity = error
dotnet_diagnostic.CA3003.severity = error
dotnet_diagnostic.CA3004.severity = warning
dotnet_diagnostic.CA3006.severity = error
dotnet_diagnostic.CA3007.severity = error
dotnet_diagnostic.CA5350.severity = error
dotnet_diagnostic.CA5351.severity = error
dotnet_diagnostic.CA5369.severity = warning

# === GLOBALIZATION ===
dotnet_diagnostic.CA1303.severity = warning
dotnet_diagnostic.CA1309.severity = warning

# === LOW-VALUE SUPPRESSIONS (existing codebase, revisit after cleanup) ===
dotnet_diagnostic.CA1030.severity = none
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.MA0016.severity = none

# === CODE REVIEW NOISE (intentional / legacy) ===
dotnet_diagnostic.CA1008.severity = none
dotnet_diagnostic.CA1055.severity = none
dotnet_diagnostic.CA1056.severity = none
dotnet_diagnostic.CA1032.severity = none
dotnet_diagnostic.CA1304.severity = none
dotnet_diagnostic.CA1308.severity = none
dotnet_diagnostic.CA1311.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1724.severity = none
dotnet_diagnostic.CA1725.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1819.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA1848.severity = suggestion
dotnet_diagnostic.CA1849.severity = suggestion
dotnet_diagnostic.CA1873.severity = none
dotnet_diagnostic.CA2227.severity = none
dotnet_diagnostic.CA5394.severity = none
dotnet_diagnostic.CA1861.severity = suggestion
dotnet_diagnostic.MA0002.severity = none
dotnet_diagnostic.MA0004.severity = suggestion
dotnet_diagnostic.MA0006.severity = none
dotnet_diagnostic.MA0011.severity = suggestion
dotnet_diagnostic.MA0015.severity = none
dotnet_diagnostic.MA0048.severity = none
dotnet_diagnostic.MA0051.severity = none
dotnet_diagnostic.RCS1194.severity = none
dotnet_diagnostic.S927.severity = none
dotnet_diagnostic.S1075.severity = none
dotnet_diagnostic.S1481.severity = none
dotnet_diagnostic.S2325.severity = none
dotnet_diagnostic.S2933.severity = none
dotnet_diagnostic.S3260.severity = none
dotnet_diagnostic.S3459.severity = none
dotnet_diagnostic.S3993.severity = none
dotnet_diagnostic.S4487.severity = none
dotnet_diagnostic.S4502.severity = none
dotnet_diagnostic.S4790.severity = none
dotnet_diagnostic.S5332.severity = none
dotnet_diagnostic.S6580.severity = none
dotnet_diagnostic.S6608.severity = none
dotnet_diagnostic.S6932.severity = none
dotnet_diagnostic.S6966.severity = none
dotnet_diagnostic.S7039.severity = none

# === NAMING ===
dotnet_naming_rule.private_fields_rule.symbols = private_fields
dotnet_naming_rule.private_fields_rule.style = underscore_prefix
dotnet_naming_rule.private_fields_rule.severity = warning
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

dotnet_naming_rule.local_functions_rule.symbols = local_functions
dotnet_naming_rule.local_functions_rule.style = pascal
dotnet_naming_rule.local_functions_rule.severity = warning
dotnet_naming_symbols.local_functions.applicable_kinds = local_function
dotnet_naming_style.pascal.capitalization = pascal_case

dotnet_naming_rule.methods_rule.symbols = methods
dotnet_naming_rule.methods_rule.style = pascal
dotnet_naming_rule.methods_rule.severity = warning
dotnet_naming_symbols.methods.applicable_kinds = method
dotnet_naming_style.pascal.capitalization = pascal_case

dotnet_naming_rule.properties_rule.symbols = properties
dotnet_naming_rule.properties_rule.style = pascal
dotnet_naming_rule.properties_rule.severity = warning
dotnet_naming_symbols.properties.applicable_kinds = property
dotnet_naming_style.pascal.capitalization = pascal_case

# === FORMATTING ===
csharp_style_namespace_declarations = file_scoped:silent
csharp_style_prefer_method_group_conversion = true:silent
csharp_style_prefer_top_level_statements = true:silent
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_pattern_matching_over_is_with_cast_check = true:silent
csharp_style_pattern_matching_over_as_with_null_check = true:silent
csharp_style_throw_expression = true:silent
csharp_style_prefer_null_check_over_type_check = true:silent
csharp_prefer_simple_default_expression = true:silent
csharp_style_prefer_local_over_anonymous_function = true:silent
csharp_style_prefer_index_operator = true:silent
csharp_style_prefer_range_operator = true:silent
csharp_style_implicit_object_creation_when_type_is_apparent = true:silent
csharp_style_prefer_tuple_swap = true:silent
csharp_style_prefer_utf8_string_literals = true:silent
csharp_style_allow_embedded_statements_on_same_line_explicit = true:silent

[test*/**/*.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA1502.severity = none
dotnet_diagnostic.CA1506.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA1861.severity = none
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.S138.severity = none
dotnet_diagnostic.S3168.severity = none
dotnet_diagnostic.S6608.severity = none
dotnet_diagnostic.MA0016.severity = none
