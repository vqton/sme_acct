@{
    ViewData["Title"] = "Accounts Payable";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Accounts Payable</h1>
</div>

<p class="text-muted">Vendor invoices, payments, and aging reports.</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Vendors</h5>
                <p class="card-text text-muted small">Manage vendor information and contact details.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Purchase Invoices</h5>
                <p class="card-text text-muted small">Record and track purchase invoices from vendors.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Payments</h5>
                <p class="card-text text-muted small">Process payments to vendors and track payment history.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
