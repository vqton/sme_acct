@{
    ViewData["Title"] = "Fixed Assets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Fixed Assets</h1>
</div>

<p class="text-muted">Asset register, depreciation, and disposal management.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Asset Register</h5>
                <p class="card-text text-muted small">Track fixed assets, acquisition details, and location.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Depreciation</h5>
                <p class="card-text text-muted small">Calculate and post depreciation schedules.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
