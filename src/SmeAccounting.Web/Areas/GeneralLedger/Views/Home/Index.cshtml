@{
    ViewData["Title"] = "General Ledger";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">General Ledger</h1>
</div>

<p class="text-muted">Journal entries, chart of accounts, and ledger management.</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Chart of Accounts</h5>
                <p class="card-text text-muted small">Manage your chart of accounts — create, edit, and organize account hierarchy.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Journal Entries</h5>
                <p class="card-text text-muted small">Record, edit, approve, and post journal entries to the general ledger.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Ledger</h5>
                <p class="card-text text-muted small">View account balances and drill into transaction details.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
