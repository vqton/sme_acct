@{
    ViewData["Title"] = "Tax Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Tax Management</h1>
</div>

<p class="text-muted">Tax declarations, payments, and reports.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Tax Declarations</h5>
                <p class="card-text text-muted small">Prepare and submit tax declarations to authorities.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Tax Reports</h5>
                <p class="card-text text-muted small">View tax summaries and filing history.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
