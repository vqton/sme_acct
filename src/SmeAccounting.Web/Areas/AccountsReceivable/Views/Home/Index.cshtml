@{
    ViewData["Title"] = "Accounts Receivable";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Accounts Receivable</h1>
</div>

<p class="text-muted">Customer invoices, collections, and aging reports.</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Customers</h5>
                <p class="card-text text-muted small">Manage customer information and credit terms.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Sales Invoices</h5>
                <p class="card-text text-muted small">Issue invoices to customers and track revenue.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Collections</h5>
                <p class="card-text text-muted small">Track payments received and manage overdue accounts.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
