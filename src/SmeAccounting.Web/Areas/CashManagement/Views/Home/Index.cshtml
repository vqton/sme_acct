@{
    ViewData["Title"] = "Cash & Bank Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Cash & Bank Management</h1>
</div>

<p class="text-muted">Cash receipts, cash payments, and bank reconciliation.</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Cash Receipts</h5>
                <p class="card-text text-muted small">Record incoming cash transactions.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Cash Payments</h5>
                <p class="card-text text-muted small">Record outgoing cash transactions.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Bank Reconciliation</h5>
                <p class="card-text text-muted small">Reconcile bank statements with book records.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
