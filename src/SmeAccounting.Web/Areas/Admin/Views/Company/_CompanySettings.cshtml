@model CompanySettingsForm

<div class="card shadow-sm">
    <div class="card-header bg-white"><strong>Accounting Settings</strong></div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Company" asp-action="UpdateSettings" method="post">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="FiscalYearStartMonth" class="form-label small"></label>
                    <select asp-for="FiscalYearStartMonth" class="form-select">
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="7">July</option>
                        <option value="10">October</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="CurrencyCode" class="form-label small"></label>
                    <select asp-for="CurrencyCode" class="form-select">
                        <option value="VND">VND</option>
                        <option value="USD">USD</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DecimalPlaces" class="form-label small"></label>
                    <select asp-for="DecimalPlaces" class="form-select">
                        <option value="0">0</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="InventoryMethod" class="form-label small"></label>
                    <select asp-for="InventoryMethod" class="form-select">
                        <option value="">Select</option>
                        <option value="FIFO">FIFO</option>
                        <option value="LIFO">LIFO</option>
                        <option value="Average">Average</option>
                        <option value="Specific">Specific Identification</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TaxMethod" class="form-label small"></label>
                    <select asp-for="TaxMethod" class="form-select">
                        <option value="">Select</option>
                        <option value="Direct">Direct Method</option>
                        <option value="Deduction">Deduction Method</option>
                    </select>
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input asp-for="EnableMultiCurrency" class="form-check-input" />
                        <label asp-for="EnableMultiCurrency" class="form-check-label small">Enable multi-currency</label>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="EnableDepartmentManagement" class="form-check-input" />
                        <label asp-for="EnableDepartmentManagement" class="form-check-label small">Enable department management</label>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>
