@model CompanyInfoForm
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf

<div class="card shadow-sm">
    <div class="card-header bg-white"><strong>Company Information</strong></div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Company" asp-action="UpdateInfo" method="post">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label small"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TaxCode" class="form-label small"></label>
                    <input asp-for="TaxCode" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label small"></label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label small"></label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label small"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Website" class="form-label small"></label>
                    <input asp-for="Website" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="LegalRepresentative" class="form-label small"></label>
                    <input asp-for="LegalRepresentative" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="RepPosition" class="form-label small"></label>
                    <input asp-for="RepPosition" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>
