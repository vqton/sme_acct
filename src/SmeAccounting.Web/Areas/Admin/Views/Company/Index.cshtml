@model CompanyViewModel
@{
    ViewData["Title"] = "Company";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Company</h1>
</div>

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-building" style="font-size: 4rem; color: var(--bs-primary);"></i>
                <h5 class="mt-2 mb-0">@Model.Info.Name</h5>
                <small class="text-muted">@Model.Info.TaxCode</small>
            </div>
            <div class="list-group list-group-flush border-top">
                <a href="@Url.Action("Index", new { tab = "info" })"
                   class="list-group-item list-group-item-action d-flex align-items-center gap-2 @(Model.ActiveTab == "info" ? "active" : "")">
                    <i class="bi bi-info-circle"></i> Company Info
                </a>
                <a href="@Url.Action("Index", new { tab = "settings" })"
                   class="list-group-item list-group-item-action d-flex align-items-center gap-2 @(Model.ActiveTab == "settings" ? "active" : "")">
                    <i class="bi bi-gear"></i> Settings
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        @if (Model.ActiveTab == "info")
        {
            @await Html.PartialAsync("_CompanyInfo", Model.Info)
        }
        else if (Model.ActiveTab == "settings")
        {
            @await Html.PartialAsync("_CompanySettings", Model.Settings)
        }
    </div>
</div>
