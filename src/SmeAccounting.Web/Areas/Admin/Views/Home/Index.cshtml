@{
    ViewData["Title"] = "Administration";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Administration</h1>
</div>

<p class="text-muted">User management, role permissions, audit log, and system settings.</p>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="card-text text-muted small">Manage user accounts and access.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Roles</h5>
                <p class="card-text text-muted small">Define roles and assign permissions.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Audit Log</h5>
                <p class="card-text text-muted small">View system audit trail.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Settings</h5>
                <p class="card-text text-muted small">System configuration and preferences.</p>
                <span class="badge bg-secondary">Coming soon</span>
            </div>
        </div>
    </div>
</div>
