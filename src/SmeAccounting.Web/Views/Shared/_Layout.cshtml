<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmeAccounting</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmeAccounting.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">
        <nav class="d-flex flex-column flex-shrink-0 p-3 bg-dark text-white" style="width: 250px;">
            <a class="d-flex align-items-center mb-3 text-white text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                <strong class="fs-5">SmeAccounting</strong>
            </a>
            <hr class="text-secondary" />
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <small class="text-secondary text-uppercase px-2">Accounting</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="GeneralLedger" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-journal-text me-2"></i>General Ledger
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="AccountsPayable" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-arrow-down-circle me-2"></i>Accounts Payable
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="AccountsReceivable" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-arrow-up-circle me-2"></i>Accounts Receivable
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="CashManagement" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-cash-stack me-2"></i>Cash &amp; Bank
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="FixedAssets" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-building me-2"></i>Fixed Assets
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Tax" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Tax
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Reports" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-bar-chart me-2"></i>Reports
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <small class="text-secondary text-uppercase px-2">Administration</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-gear me-2"></i>Admin
                    </a>
                </li>
            </ul>
        </nav>

        <main class="flex-grow-1 d-flex flex-column">
            <nav class="navbar navbar-expand navbar-light bg-white border-bottom shadow-sm px-4">
                <div class="container-fluid justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @(User.Identity?.Name ?? "Guest")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text small text-muted">@(User.Identity?.Name ?? "")</span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-1"></i> Sign out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </nav>
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
            <footer class="mt-auto text-center text-muted small py-3 border-top">
                &copy; 2026 SmeAccounting
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
