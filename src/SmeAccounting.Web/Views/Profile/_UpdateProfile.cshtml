@model UpdateProfileForm

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <strong>Personal Information</strong>
    </div>
    <div class="card-body">
        <form asp-action="UpdateProfile" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label small"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label small"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label small"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DateOfBirth" class="form-label small"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Gender" class="form-label small"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="JobTitle" class="form-label small"></label>
                    <input asp-for="JobTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Department" class="form-label small"></label>
                    <input asp-for="Department" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label small"></label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
