@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
    <span class="text-muted small">Welcome back, admin</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body">
                <h6 class="card-subtitle mb-1">Journal Entries</h6>
                <h2 class="mb-0">0</h2>
                <small class="opacity-75">This period</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body">
                <h6 class="card-subtitle mb-1">Total Debits</h6>
                <h2 class="mb-0">0</h2>
                <small class="opacity-75">This period</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-warning text-white">
            <div class="card-body">
                <h6 class="card-subtitle mb-1">Total Credits</h6>
                <h2 class="mb-0">0</h2>
                <small class="opacity-75">This period</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-info text-white">
            <div class="card-body">
                <h6 class="card-subtitle mb-1">Active Accounts</h6>
                <h2 class="mb-0">0</h2>
                <small class="opacity-75">Of 0 total</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>Recent Journal Entries</strong>
                <span class="text-muted small">No entries yet</span>
            </div>
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-journal-plus" style="font-size: 3rem;"></i>
                <p class="mt-2 mb-0">Record your first journal entry from the General Ledger module.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>Account Summary</strong>
            </div>
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-pie-chart" style="font-size: 3rem;"></i>
                <p class="mt-2 mb-0">No accounts configured.</p>
            </div>
        </div>
    </div>
</div>
