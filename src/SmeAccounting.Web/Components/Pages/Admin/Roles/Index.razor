@page "/admin/roles"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Roles.Commands
@using SmeAccounting.Application.Admin.Roles.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>Role Management</h3>

<div class="margin-bottom-2">
    <button class="button tiny success" @onclick="GoCreate">Create Role</button>
</div>

@if (loading)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>System</th>
            <th>Users</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var role in roles ?? new())
        {
            <tr>
                <td>@role.Name</td>
                <td>@role.Description</td>
                <td>
                    @if (role.IsSystem)
                    {
                        <span class="label info">System</span>
                    }
                </td>
                <td>@role.UserCount</td>
                <td>
                    <button class="button tiny hollow primary margin-right-1" @onclick='() => GoRole(role.Id)'>Edit</button>
                    @if (!role.IsSystem)
                    {
                        <button class="button tiny hollow alert" @onclick='() => ConfirmDelete(role.Id, role.Name)'>Delete</button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (showConfirm)
{
    <div class="callout alert margin-top-2">
        <p>Delete role <strong>@deleteTargetName</strong>? This cannot be undone.</p>
        <button class="button tiny alert" @onclick="ExecuteDelete">Confirm Delete</button>
        <button class="button tiny secondary margin-left-1" @onclick='() => { showConfirm = false; }'>Cancel</button>
    </div>
}

@code {
    private List<RoleListItemDto>? roles;
    private bool loading;

    private bool showConfirm;
    private Guid deleteTargetId;
    private string deleteTargetName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var r = await Mediator.Send(new ListRolesQuery());
            if (r.IsSuccess) roles = r.Value;
        }
        finally
        {
            loading = false;
        }
    }

    private void ConfirmDelete(Guid id, string name)
    {
        deleteTargetId = id;
        deleteTargetName = name;
        showConfirm = true;
    }

    private async Task ExecuteDelete()
    {
        showConfirm = false;
        var r = await Mediator.Send(new DeleteRoleCommand(deleteTargetId));
        if (r.IsSuccess)
        {
            var reload = await Mediator.Send(new ListRolesQuery());
            if (reload.IsSuccess) roles = reload.Value;
        }
    }

    private void GoCreate() => Navigation.NavigateTo("/admin/roles/create");
    private void GoRole(Guid id) => Navigation.NavigateTo($"/admin/roles/{id}");
}
