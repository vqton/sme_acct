@page "/admin/roles/create"
@page "/admin/roles/{Id:guid}"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Roles.Commands
@using SmeAccounting.Application.Admin.Roles.Queries
@using SmeAccounting.Application.Admin.Permissions.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>@(IsCreate ? "Create Role" : "Edit Role")</h3>

<EditForm Model="model" OnValidSubmit="Save">
    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText @bind-Value="model.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <InputText @bind-Value="model.Description" class="form-control" />
    </div>

    @if (permissions is not null)
    {
        <h5 class="mt-4">Permissions</h5>
        <table class="table table-sm">
            <thead>
            <tr><th>Resource</th><th>Action</th><th>Granted</th></tr>
            </thead>
            <tbody>
            @foreach (var perm in permissions)
            {
                <tr>
                    <td>@perm.Resource</td>
                    <td>@perm.Action</td>
                    <td>
                        <input type="checkbox" checked="@perm.IsAssigned"
                               @onchange='(e) => TogglePermission(perm.PermissionId, (bool)(e.Value ?? false))' />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <button type="submit" class="btn btn-primary">Save</button>
    <button class="btn btn-secondary ms-2" @onclick="GoBack">Cancel</button>
</EditForm>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsCreate => !Id.HasValue || Id == Guid.Empty;
    private RoleEditModel model = new();
    private List<PermissionAssignmentDto>? permissions;

    protected override async Task OnInitializedAsync()
    {
        var permsResult = await Mediator.Send(new ListPermissionsQuery());
        var allPermissions = permsResult.IsSuccess ? permsResult.Value : new();

        if (!IsCreate)
        {
            var r = await Mediator.Send(new GetRoleQuery(Id!.Value));
            if (r.IsSuccess)
            {
                var role = r.Value;
                model.Name = role.Name;
                model.Description = role.Description;

                var assignedIds = role.Permissions.Where(p => p.IsAssigned).Select(p => p.PermissionId).ToHashSet();
                permissions = allPermissions.Select(p => new PermissionAssignmentDto(
                    p.Id, p.Code, p.Name, p.Resource, p.Action, assignedIds.Contains(p.Id))).ToList();
            }
        }
        else
        {
            permissions = allPermissions.Select(p => new PermissionAssignmentDto(
                p.Id, p.Code, p.Name, p.Resource, p.Action, false)).ToList();
        }
    }

    private async Task TogglePermission(Guid permissionId, bool granted)
    {
        if (Id is null) return;

        if (granted)
            await Mediator.Send(new AssignPermissionCommand(Id.Value, permissionId));
        else
            await Mediator.Send(new RemovePermissionCommand(Id.Value, permissionId));
    }

    private async Task Save()
    {
        if (IsCreate)
        {
            var selected = permissions?.Where(p => p.IsAssigned).Select(p => p.PermissionId).ToList();
            var r = await Mediator.Send(new CreateRoleCommand(model.Name, model.Description, Guid.Empty, selected));
            if (r.IsSuccess) GoBack();
        }
        else
        {
            var r = await Mediator.Send(new UpdateRoleCommand(Id!.Value, model.Name, model.Description));
            if (r.IsSuccess) GoBack();
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin/roles");

    private class RoleEditModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
