@page "/admin/users"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Users.Commands
@using SmeAccounting.Application.Admin.Users.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>User Management</h3>

<div class="margin-bottom-2">
    <input @bind="search" @bind:event="oninput" placeholder="Search by username, email, or name..." style="width:300px" />
    <button class="button tiny primary margin-left-1" @onclick="LoadUsers">Search</button>
    <button class="button tiny success margin-left-1" @onclick="GoCreate">Create User</button>
</div>

@if (loading)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Full Name</th>
            <th>Active</th>
            <th>Roles</th>
            <th>Last Login</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var user in result?.Items ?? new())
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="label success">Active</span>
                    }
                    else
                    {
                        <span class="label alert">Inactive</span>
                    }
                </td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>@user.LastLogin?.ToString("g")</td>
                <td class="grid-x grid-margin-x">
                    <div class="cell shrink">
                        <button class="button tiny hollow primary" @onclick='() => GoUser(user.Id)'>View</button>
                    </div>
                    <div class="cell shrink">
                        <button class="button tiny hollow secondary" @onclick='() => GoEdit(user.Id)'>Edit</button>
                    </div>
                    <div class="cell shrink">
                        <button class="button tiny hollow alert" @onclick='() => ConfirmDelete(user.Id, user.Username)'>Delete</button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @if (result is not null)
    {
        <div class="margin-top-2">
            <span class="text-muted">Page @result.Page of @((int)Math.Ceiling((double)result.TotalCount / Math.Max(result.PageSize, 1))) (@result.TotalCount users)</span>
        </div>
    }
}

@if (showConfirm)
{
    <div class="callout alert margin-top-2">
        <p>Delete user <strong>@deleteTargetUsername</strong>? This cannot be undone.</p>
        <button class="button tiny alert" @onclick="ExecuteDelete">Confirm Delete</button>
        <button class="button tiny secondary margin-left-1" @onclick='() => { showConfirm = false; }'>Cancel</button>
    </div>
}

@code {
    private string? search;
    private PaginatedUsersResult? result;
    private bool loading;

    private bool showConfirm;
    private Guid deleteTargetId;
    private string deleteTargetUsername = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        loading = true;
        try
        {
            var r = await Mediator.Send(new ListUsersQuery(Search: search));
            if (r.IsSuccess) result = r.Value;
        }
        finally
        {
            loading = false;
        }
    }

    private void ConfirmDelete(Guid id, string username)
    {
        deleteTargetId = id;
        deleteTargetUsername = username;
        showConfirm = true;
    }

    private async Task ExecuteDelete()
    {
        showConfirm = false;
        var r = await Mediator.Send(new DeleteUserCommand(deleteTargetId));
        if (r.IsSuccess)
            await LoadUsers();
    }

    private void GoCreate() => Navigation.NavigateTo("/admin/users/create");
    private void GoUser(Guid id) => Navigation.NavigateTo($"/admin/users/{id}");
    private void GoEdit(Guid id) => Navigation.NavigateTo($"/admin/users/{id}/edit");
}
