@page "/admin/users/create"
@page "/admin/users/{Id:guid}/edit"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Users.Commands
@using SmeAccounting.Application.Admin.Users.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>@(IsCreate ? "Create User" : "Edit User")</h3>

<EditForm Model="model" OnValidSubmit="Save">
    <div class="margin-bottom-2">
        <label>Username</label>
        <InputText @bind-Value="model.Username" disabled="@(!IsCreate)" />
    </div>
    <div class="margin-bottom-2">
        <label>Email</label>
        <InputText @bind-Value="model.Email" />
    </div>
    <div class="margin-bottom-2">
        <label>First Name</label>
        <InputText @bind-Value="model.FirstName" />
    </div>
    <div class="margin-bottom-2">
        <label>Last Name</label>
        <InputText @bind-Value="model.LastName" />
    </div>
    @if (IsCreate)
    {
        <div class="margin-bottom-2">
            <label>Password</label>
            <InputText @bind-Value="model.Password" type="password" />
        </div>
    }
    <div class="margin-bottom-2">
        <label>
            <InputCheckbox @bind-Value="model.IsActive" disabled="@IsCreate" />
            Active
        </label>
    </div>
    <button type="submit" class="button tiny primary">Save</button>
    <button class="button tiny secondary margin-left-1" @onclick="GoBack">Cancel</button>
</EditForm>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsCreate => !Id.HasValue || Id == Guid.Empty;
    private UserEditModel model = new();

    protected override async Task OnInitializedAsync()
    {
        if (!IsCreate)
        {
            var r = await Mediator.Send(new GetUserQuery(Id!.Value));
            if (r.IsSuccess)
            {
                var u = r.Value;
                model.Username = u.Username;
                model.Email = u.Email;
                model.FirstName = u.FirstName;
                model.LastName = u.LastName;
                model.IsActive = u.IsActive;
            }
        }
    }

    private async Task Save()
    {
        if (IsCreate)
        {
            var cmd = new CreateUserCommand(model.Username, model.Email, model.Password!, model.FirstName, model.LastName, Guid.Empty);
            var r = await Mediator.Send(cmd);
            if (r.IsSuccess) GoBack();
        }
        else
        {
            var cmd = new UpdateUserCommand(Id!.Value, model.Email, model.FirstName, model.LastName, model.IsActive);
            var r = await Mediator.Send(cmd);
            if (r.IsSuccess) GoBack();
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin/users");

    private class UserEditModel
    {
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Password { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}
