@page "/admin/users/{Id:guid}"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Users.Commands
@using SmeAccounting.Application.Admin.Users.Queries
@using SmeAccounting.Application.Admin.Roles.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>User Detail</h3>

@if (loading)
{
    <p>Loading...</p>
}
else if (user is null)
{
    <p>User not found.</p>
}
else
{
    <div class="row mb-4">
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-4">Username</dt>
                <dd class="col-sm-8">@user.Username</dd>
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@user.Email</dd>
                <dt class="col-sm-4">Full Name</dt>
                <dd class="col-sm-8">@user.FullName</dd>
                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </dd>
                <dt class="col-sm-4">MFA</dt>
                <dd class="col-sm-8">@(user.MfaEnabled ? "Enabled" : "Disabled")</dd>
                <dt class="col-sm-4">Last Login</dt>
                <dd class="col-sm-8">@user.LastLogin?.ToString("g")</dd>
                <dt class="col-sm-4">Created</dt>
                <dd class="col-sm-8">@user.CreatedAt.ToString("g")</dd>
            </dl>
            <button class="btn btn-primary me-2" @onclick='() => GoEdit(user.Id)'>Edit</button>
            <button class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
        </div>
        <div class="col-md-6">
            <h5>Role Assignment</h5>
            @if (allRoles is not null)
            {
                <table class="table table-sm">
                    <thead>
                    <tr><th>Role</th><th>Description</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var role in allRoles)
                    {
                        var assigned = user.Roles.Any(r => r.RoleId == role.Id);
                        <tr>
                            <td>@role.Name</td>
                            <td>@role.Description</td>
                            <td>
                                @if (assigned)
                                {
                                    <button class="btn btn-sm btn-danger" @onclick='() => Unassign(role.Id)'>Remove</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success" @onclick='() => Assign(role.Id)'>Assign</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private UserDetailDto? user;
    private List<RoleListItemDto>? allRoles;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var userResult = await Mediator.Send(new GetUserQuery(Id));
            if (userResult.IsSuccess) user = userResult.Value;

            var rolesResult = await Mediator.Send(new ListRolesQuery());
            if (rolesResult.IsSuccess) allRoles = rolesResult.Value;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Assign(Guid roleId)
    {
        await Mediator.Send(new AssignRoleCommand(Id, roleId));
        Navigation.NavigateTo($"/admin/users/{Id}", forceLoad: true);
    }

    private async Task Unassign(Guid roleId)
    {
        await Mediator.Send(new UnassignRoleCommand(Id, roleId));
        Navigation.NavigateTo($"/admin/users/{Id}", forceLoad: true);
    }

    private void GoEdit(Guid id) => Navigation.NavigateTo($"/admin/users/{id}/edit");
    private void GoBack() => Navigation.NavigateTo("/admin/users");
}
