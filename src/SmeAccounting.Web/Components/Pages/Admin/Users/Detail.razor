@page "/admin/users/{Id:guid}"
@attribute [Authorize]
@using SmeAccounting.Application.Admin.Users.Commands
@using SmeAccounting.Application.Admin.Users.Queries
@using SmeAccounting.Application.Admin.Roles.Queries
@inject IMediator Mediator
@inject NavigationManager Navigation

<h3>User Detail</h3>

@if (loading)
{
    <p>Loading...</p>
}
else if (user is null)
{
    <p>User not found.</p>
}
else
{
    <div class="grid-x grid-margin-x margin-bottom-3">
        <div class="cell medium-6">
            <div class="margin-bottom-2">
                <strong>Username</strong><br />
                <span>@user.Username</span>
            </div>
            <div class="margin-bottom-2">
                <strong>Email</strong><br />
                <span>@user.Email</span>
            </div>
            <div class="margin-bottom-2">
                <strong>Full Name</strong><br />
                <span>@user.FullName</span>
            </div>
            <div class="margin-bottom-2">
                <strong>Status</strong><br />
                @if (user.IsActive)
                {
                    <span class="label success">Active</span>
                }
                else
                {
                    <span class="label alert">Inactive</span>
                }
            </div>
            <div class="margin-bottom-2">
                <strong>MFA</strong><br />
                <span>@(user.MfaEnabled ? "Enabled" : "Disabled")</span>
            </div>
            <div class="margin-bottom-2">
                <strong>Last Login</strong><br />
                <span>@user.LastLogin?.ToString("g")</span>
            </div>
            <div class="margin-bottom-2">
                <strong>Created</strong><br />
                <span>@user.CreatedAt.ToString("g")</span>
            </div>
            <button class="button tiny primary margin-right-1" @onclick='() => GoEdit(user.Id)'>Edit</button>
            <button class="button tiny hollow secondary" @onclick="GoBack">Back</button>
        </div>
        <div class="cell medium-6">
            <h5>Role Assignment</h5>
            @if (allRoles is not null)
            {
                <table class="table">
                    <thead>
                    <tr><th>Role</th><th>Description</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var role in allRoles)
                    {
                        var assigned = user.Roles.Any(r => r.RoleId == role.Id);
                        <tr>
                            <td>@role.Name</td>
                            <td>@role.Description</td>
                            <td>
                                @if (assigned)
                                {
                                    <button class="button tiny alert" @onclick='() => Unassign(role.Id)'>Remove</button>
                                }
                                else
                                {
                                    <button class="button tiny success" @onclick='() => Assign(role.Id)'>Assign</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private UserDetailDto? user;
    private List<RoleListItemDto>? allRoles;
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var userResult = await Mediator.Send(new GetUserQuery(Id));
            if (userResult.IsSuccess) user = userResult.Value;

            var rolesResult = await Mediator.Send(new ListRolesQuery());
            if (rolesResult.IsSuccess) allRoles = rolesResult.Value;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Assign(Guid roleId)
    {
        await Mediator.Send(new AssignRoleCommand(Id, roleId));
        Navigation.NavigateTo($"/admin/users/{Id}", forceLoad: true);
    }

    private async Task Unassign(Guid roleId)
    {
        await Mediator.Send(new UnassignRoleCommand(Id, roleId));
        Navigation.NavigateTo($"/admin/users/{Id}", forceLoad: true);
    }

    private void GoEdit(Guid id) => Navigation.NavigateTo($"/admin/users/{id}/edit");
    private void GoBack() => Navigation.NavigateTo("/admin/users");
}
