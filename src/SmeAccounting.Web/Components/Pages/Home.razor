@page "/"
@attribute [Authorize]
@using System.Security.Claims
@using SmeAccounting.Application.GeneralLedger.Queries.GetDashboardData
@inject IMediator Mediator
@inject AuthenticationStateProvider AuthState

<PageTitle>Dashboard - SmeAccounting</PageTitle>

@if (_loading)
{
    <div class="flex-container align-center margin-top-3">
        <div class="spinner" role="status">
            <span class="show-for-sr">Loading...</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="callout alert">@_error</div>
}
else if (_data is not null)
{
    <div class="grid-container fluid">
        <div class="flex-container align-justify align-middle margin-bottom-2">
            <h2 class="margin-0">@_data.CompanyName</h2>
            <div class="flex-container align-middle">
                @if (_data.CurrentPeriodLabel is not null)
                {
                    <span class="label primary margin-right-1">@_data.CurrentPeriodLabel</span>
                }
                <button class="button primary hollow tiny" @onclick="Refresh" disabled="@_loading">
                    Refresh
                </button>
            </div>
        </div>

        <div class="grid-x grid-margin-x margin-bottom-2">
            <div class="cell medium-3">
                <div class="card kpi-card kpi-primary">
                    <div class="card-section">
                        <h6 class="subheader">Posted Entries</h6>
                        <h3 class="primary margin-0">@_data.TotalPostedEntries</h3>
                        <small class="text-muted">@_data.PostedEntriesThisPeriod this period</small>
                    </div>
                </div>
            </div>
            <div class="cell medium-3">
                <div class="card kpi-card kpi-success">
                    <div class="card-section">
                        <h6 class="subheader">Total Debits</h6>
                        <h3 class="success margin-0">@FormatAmount(_data.TotalDebitsThisPeriod)</h3>
                        <small class="text-muted">This period</small>
                    </div>
                </div>
            </div>
            <div class="cell medium-3">
                <div class="card kpi-card kpi-alert">
                    <div class="card-section">
                        <h6 class="subheader">Total Credits</h6>
                        <h3 class="alert margin-0">@FormatAmount(_data.TotalCreditsThisPeriod)</h3>
                        <small class="text-muted">This period</small>
                    </div>
                </div>
            </div>
            <div class="cell medium-3">
                <div class="card kpi-card kpi-warning">
                    <div class="card-section">
                        <h6 class="subheader">Draft Entries</h6>
                        <h3 class="warning margin-0">@_data.DraftEntries</h3>
                        <small class="text-muted">@_data.ActiveUsers active users</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid-x grid-margin-x margin-bottom-2">
            <div class="cell medium-8">
                <div class="card">
                    <div class="card-divider flex-container align-justify align-middle">
                        <strong>Account Summary</strong>
                        <span class="text-muted small">@_data.ActiveAccounts / @_data.TotalAccounts active</span>
                    </div>
                    <div class="card-section">
                        <div class="grid-x text-center">
                            <div class="cell medium-4 margin-bottom-1">
                                <div class="padding-1 bg-light rounded">
                                    <h5 class="margin-0">@_data.AssetAccounts</h5>
                                    <small class="text-muted">Assets</small>
                                </div>
                            </div>
                            <div class="cell medium-4 margin-bottom-1">
                                <div class="padding-1 bg-light rounded">
                                    <h5 class="margin-0">@_data.LiabilityAccounts</h5>
                                    <small class="text-muted">Liabilities</small>
                                </div>
                            </div>
                            <div class="cell medium-4 margin-bottom-1">
                                <div class="padding-1 bg-light rounded">
                                    <h5 class="margin-0">@_data.EquityAccounts</h5>
                                    <small class="text-muted">Equity</small>
                                </div>
                            </div>
                            <div class="cell medium-6">
                                <div class="padding-1 bg-light rounded">
                                    <h5 class="margin-0">@_data.RevenueAccounts</h5>
                                    <small class="text-muted">Revenue</small>
                                </div>
                            </div>
                            <div class="cell medium-6">
                                <div class="padding-1 bg-light rounded">
                                    <h5 class="margin-0">@_data.ExpenseAccounts</h5>
                                    <small class="text-muted">Expenses</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="cell medium-4">
                <div class="card">
                    <div class="card-divider"><strong>Top-Level Accounts</strong></div>
                    <div class="card-section padding-0">
                        <table class="table-sm margin-0">
                            <thead>
                                <tr><th>Account</th><th class="text-right">Balance</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var acc in _data.TopLevelAccountBalances)
                                {
                                    <tr>
                                        <td><small>@acc.AccountCode - @acc.AccountName</small></td>
                                        <td class="text-right"><small>@FormatAmount(acc.Balance)</small></td>
                                    </tr>
                                }
                                @if (_data.TopLevelAccountBalances.Count == 0)
                                {
                                    <tr><td colspan="2" class="text-muted text-center"><small>No accounts</small></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-divider flex-container align-justify align-middle">
                <strong>Recent Journal Entries</strong>
            </div>
            <div class="card-section padding-0">
                <table class="table-sm margin-0">
                    <thead>
                        <tr><th>#</th><th>Description</th><th>Date</th><th>Status</th><th class="text-right">Amount</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _data.RecentEntries)
                        {
                            <tr>
                                <td><small>@e.EntryNumber</small></td>
                                <td><small>@e.Description</small></td>
                                <td><small>@e.PostingDate.ToString("dd/MM/yyyy")</small></td>
                                <td><span class="label @(e.Status == "Posted" ? "success" : "warning")">@e.Status</span></td>
                                <td class="text-right"><small>@FormatAmount(e.Total)</small></td>
                            </tr>
                        }
                        @if (_data.RecentEntries.Count == 0)
                        {
                            <tr><td colspan="5" class="text-muted text-center"><small>No entries yet</small></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private DashboardDataDto? _data;
    private string? _error;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task Refresh()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        if (_loading) return;
        _loading = true;
        _error = null;

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var uid = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (uid is null || !Guid.TryParse(uid, out var userId))
            {
                _error = "User identity not available";
                return;
            }

            var result = await Mediator.Send(new GetDashboardDataQuery(userId));
            if (result.IsSuccess)
                _data = result.Value;
            else
                _error = result.Errors.First().Message;
        }
        catch (Exception ex)
        {
            _error = "Failed to load dashboard data: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatAmount(decimal amount) =>
        amount.ToString("N0") + " VND";
}
